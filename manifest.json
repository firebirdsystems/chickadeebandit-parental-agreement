{
  "id": "parental-agreement",
  "contexts": ["household", "shared_space"],
  "name": "Parental Agreement",
  "version": "1.1.0",
  "description": "Kids submit permission requests — staying out late, attending events, overnight trips. Parents are notified and must approve. Any edit resets approval and re-notifies parents.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": [
    "parenting",
    "permissions",
    "kids",
    "agreements",
    "curfew"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "permissions": {
      "kind": "owner_only",
      "member_column": "child_id",
      "adults_bypass": true
    },
    "decisions": {
      "kind": "adult_writable",
      "member_read_column": "child_id",
      "endpoint_writes_only": true
    },
    "activity": {
      "kind": "owner_only",
      "member_column": "actor_id",
      "adults_bypass": true,
      "member_can_update": false,
      "endpoint_writes_only": true
    }
  },
  "append_only_records": {
    "decisions": {
      "table": "decisions",
      "parent_table": "permissions",
      "parent_fk_column": "permission_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["cancelled"],
      "allowed_columns": ["permission_id", "child_id", "decision", "note"],
      "writer_column": "decided_by",
      "created_at_column": "decided_at",
      "write_acl": { "require_role": "adult" },
      "allowed_values": {
        "decision": ["approved", "rejected"]
      },
      "max_text_lengths": {
        "permission_id": 120,
        "child_id": 120,
        "decision": 20,
        "note": 1000
      }
    },
    "activity": {
      "table": "activity",
      "parent_table": "permissions",
      "parent_fk_column": "permission_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": [],
      "allowed_columns": ["permission_id", "action", "detail"],
      "writer_column": "actor_id",
      "created_at_column": "created_at",
      "allowed_values": {
        "action": ["created", "updated", "approved", "rejected", "cancelled"]
      },
      "max_text_lengths": {
        "permission_id": 120,
        "action": 40,
        "detail": 1000
      }
    }
  },
  "publish_acls": {
    "parental-agreement.approved": { "require_role": "adult" },
    "parental-agreement.rejected": { "require_role": "adult" }
  },
  "publishes": [
    "parental-agreement.approved",
    "parental-agreement.rejected"
  ],
  "alert_on": [
    "parental-agreement.approved",
    "parental-agreement.rejected"
  ],
  "nav": {
    "label": "Permissions"
  },
  "widget": {
    "label": "Permissions",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "✋"
}
